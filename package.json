{
  "name": "@dbconn/core",
  "version": "0.4.0",
  "description": "Universal database connector with dialect-safe query builders (Postgres, MySQL, MongoDB)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dbconn": "./dist/bin/migrate.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "docs"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deepa0128/dbConn.git"
  },
  "keywords": [
    "database",
    "postgres",
    "mysql",
    "mongodb",
    "query-builder",
    "sql",
    "typescript"
  ],
  "dependencies": {
    "mongodb": "^7.2.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
